<MudDialog>
	<TitleContent>
		<MudText Typo="Typo.h6">@(Pair is null ? "Add Metadata Sync Pair" : "Edit Metadata Sync Pair")</MudText>
	</TitleContent>
	<DialogContent>
		<MudStack Spacing="3">
			<MudSelect @bind-Value="_sourceServerId" Label="Source Server" Variant="Variant.Outlined"
				AnchorOrigin="Origin.BottomCenter">
				@foreach (var server in SourceServers)
				{
					<MudSelectItem Value="server.Id">@server.Name</MudSelectItem>
				}
			</MudSelect>

			<MudSelect @bind-Value="_destinationServerId" Label="Destination Server" Variant="Variant.Outlined"
				AnchorOrigin="Origin.BottomCenter">
				@foreach (var server in DestinationServers)
				{
					<MudSelectItem Value="server.Id">@server.Name</MudSelectItem>
				}
			</MudSelect>

			<MudCheckBox @bind-Value="_isEnabled" Label="Enabled" Color="Color.Primary" />
		</MudStack>
	</DialogContent>
	<DialogActions>
		<MudButton OnClick="Cancel">Cancel</MudButton>
		<MudButton Variant="Variant.Filled" Color="Color.Primary"
			OnClick="SaveAsync" Disabled="@(!CanSave || _isSaving)">
			@if (_isSaving)
			{
				<MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
			}
			Save
		</MudButton>
	</DialogActions>
</MudDialog>
