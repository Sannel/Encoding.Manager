<MudDialog>
	<TitleContent>
		<MudText Typo="Typo.h6">Queue @_itemTypeName for Encoding</MudText>
	</TitleContent>
	<DialogContent>
		<MudStack Spacing="3">
			@if (_isLoadingEpisodes)
			{
				<MudProgressCircular Indeterminate="true" Color="Color.Primary" />
			}
			else
			{
				<MudAlert Severity="Severity.Info">
					@_episodes.Count episode(s) will be queued for encoding.
				</MudAlert>

				<MudList T="string" Dense="true" Style="max-height: 300px; overflow-y: auto;">
					@foreach (var ep in _episodes)
					{
						<MudListItem T="string">
							@if (ep.ParentIndexNumber.HasValue && ep.IndexNumber.HasValue)
							{
								@($"S{ep.ParentIndexNumber:D2}E{ep.IndexNumber:D2} — {ep.Name}")
							}
							else
							{
								@ep.Name
							}
						</MudListItem>
					}
				</MudList>

				<MudSelect Value="_destServerId" Label="Destination Server" Variant="Variant.Outlined"
					AnchorOrigin="Origin.BottomCenter"
					ValueChanged="@((Guid v) => OnDestServerChangedAsync(v))">
					@foreach (var server in _destServers)
					{
						<MudSelectItem Value="server.Id">@server.Name</MudSelectItem>
					}
				</MudSelect>

				@if (_destRoots.Count > 0)
				{
					<MudSelect @bind-Value="_destRootId" Label="Destination Root" Variant="Variant.Outlined"
						AnchorOrigin="Origin.BottomCenter">
						@foreach (var root in _destRoots)
						{
							<MudSelectItem Value="root.Id">@root.Name — @root.RootPath</MudSelectItem>
						}
					</MudSelect>
				}

				<MudSelect @bind-Value="_presetLabel" Label="Encoding Preset" Variant="Variant.Outlined"
					AnchorOrigin="Origin.BottomCenter">
					@foreach (var preset in _presets)
					{
						<MudSelectItem Value="@preset.Label">@preset.Label</MudSelectItem>
					}
				</MudSelect>
			}
		</MudStack>
	</DialogContent>
	<DialogActions>
		<MudButton OnClick="Cancel">Cancel</MudButton>
		<MudButton Variant="Variant.Filled" Color="Color.Primary"
			OnClick="QueueAllAsync"
			Disabled="@(!CanQueue || _isQueueing || _isLoadingEpisodes)">
			@if (_isQueueing)
			{
				<MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
			}
			Queue @_episodes.Count Episode(s)
		</MudButton>
	</DialogActions>
</MudDialog>
