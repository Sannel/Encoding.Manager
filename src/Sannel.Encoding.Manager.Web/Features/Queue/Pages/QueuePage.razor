@page "/queue"
@rendermode InteractiveServer

<PageTitle>Encoding Queue</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Encoding Queue</MudText>

<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3" Wrap="Wrap.Wrap">
	<MudButton Variant="Variant.Outlined" Color="Color.Warning"
		StartIcon="@Icons.Material.Filled.DoneAll"
		OnClick="ClearFinishedAsync">
		Clear Finished
	</MudButton>
	<MudSwitch T="bool" Value="_showCleared" ValueChanged="OnShowClearedChanged"
		Color="Color.Primary" Label="Show Cleared" />
</MudStack>

@if (_isLoading)
{
	<MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else if (_items.Count == 0)
{
	<MudAlert Severity="Severity.Info">The encoding queue is empty.</MudAlert>
}
else
{
	<MudTable Items="_items" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
		<HeaderContent>
			<MudTh>Disc</MudTh>
			<MudTh>Mode</MudTh>
			<MudTh>Tracks</MudTh>
			<MudTh>Show</MudTh>
			<MudTh>Audio</MudTh>
			<MudTh>Status</MudTh>
			<MudTh>Queued</MudTh>
			<MudTh></MudTh>
		</HeaderContent>
		<RowTemplate>
			<MudTd DataLabel="Disc">
				<MudText Typo="Typo.body2">@DiscLabel(context.DiscPath)</MudText>
			</MudTd>
			<MudTd DataLabel="Mode">@context.Mode</MudTd>
			<MudTd DataLabel="Tracks">@GetTrackCount(context.TracksJson)</MudTd>
			<MudTd DataLabel="Show">
				@if (!string.IsNullOrEmpty(context.TvdbShowName))
				{
					@context.TvdbShowName
				}
				else
				{
					<MudText Typo="Typo.caption" Style="opacity:.6">—</MudText>
				}
			</MudTd>
			<MudTd DataLabel="Audio">@context.AudioDefault</MudTd>
			<MudTd DataLabel="Status">
				<MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Outlined">
					@context.Status
				</MudChip>
				@if (context.Status == "Encoding" && context.ProgressPercent.HasValue)
				{
					<MudStack Spacing="1" Class="mt-1" Style="min-width: 190px; max-width: 220px;">
						<MudText Typo="Typo.caption">Overall: @FormatPercent(context.ProgressPercent)%</MudText>
						<MudProgressLinear Value="@context.ProgressPercent.Value" Color="Color.Primary"
							Size="Size.Small" />
						@if (context.CurrentTrackProgressPercent.HasValue)
						{
							<MudText Typo="Typo.caption">Current track: @FormatPercent(context.CurrentTrackProgressPercent)%</MudText>
							<MudProgressLinear Value="@context.CurrentTrackProgressPercent.Value" Color="Color.Secondary"
								Size="Size.Small" />
						}
					</MudStack>
				}
			</MudTd>
			<MudTd DataLabel="Queued">
				<MudText Typo="Typo.caption">@context.CreatedAt.ToLocalTime().ToString("g")</MudText>
			</MudTd>
			<MudTd>
				<MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Default"
					Size="Size.Small" Title="View details"
					OnClick="@(() => OpenDetailDialogAsync(context))" />
				<MudIconButton Icon="@Icons.Material.Filled.StopCircle" Color="Color.Info"
					Size="Size.Small" Title="Cancel active encode"
					Disabled="@(!CanCancelEncoding(context.Status))"
					OnClick="@(() => CancelEncodingAsync(context.Id))" />
				<MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Warning"
					Size="Size.Small" Title="Reset failed/finished item to queued"
					Disabled="@(!CanResetToQueued(context.Status))"
					OnClick="@(() => RetryFailedItemAsync(context.Id))" />
				<MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
					Size="Size.Small" Title="Remove from queue"
					OnClick="@(() => DeleteItemAsync(context.Id))" />
			</MudTd>
		</RowTemplate>
	</MudTable>
}
