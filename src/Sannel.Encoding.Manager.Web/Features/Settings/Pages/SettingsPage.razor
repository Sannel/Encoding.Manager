@page "/settings"
@rendermode InteractiveServer
@using Sannel.Encoding.Manager.Web.Features.Settings.Dto

<PageTitle>Settings</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Settings</MudText>

@if (_isLoading)
{
	<MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
	<MudStack Spacing="4" Style="max-width: 700px;">

		<MudCard>
			<MudCardContent>
				<MudText Typo="Typo.h6" Class="mb-2">Track Destination</MudText>

				<MudSelect T="string?" @bind-Value="_trackDestinationRoot"
					Label="Output Root"
					Variant="Variant.Outlined"
					AnchorOrigin="Origin.BottomCenter"
					Class="mb-4"
					HelperText="Base directory for all encoded output files">
					<MudSelectItem T="string?" Value="@((string?)null)"><em>None</em></MudSelectItem>
					@foreach (var root in _roots)
					{
						<MudSelectItem T="string?" Value="@root.Label">@root.Label</MudSelectItem>
					}
				</MudSelect>

				<MudText Typo="Typo.body2" Class="mb-3">
					Sub-path template appended to the root. Supported variables:
				</MudText>
				<MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
					<MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
						OnClick="@(() => AppendToTvTemplate("{SourceDisk}"))">{SourceDisk}</MudChip>
					<MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
						OnClick="@(() => AppendToTvTemplate("{TVDBShow}"))">{TVDBShow}</MudChip>
					<MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
						OnClick="@(() => AppendToTvTemplate("{TVDBID}"))">{TVDBID}</MudChip>
					<MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
						OnClick="@(() => AppendToTvTemplate("{SeasonNumber}"))">{SeasonNumber}</MudChip>
					<MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
						OnClick="@(() => AppendToTvTemplate("{EpisodeName}"))">{EpisodeName}</MudChip>
				</MudStack>
				<MudAlert Severity="Severity.Info" Dense="true" Class="mb-3" NoIcon="false">
					<MudText Typo="Typo.caption">
						<strong>{SeasonNumber}</strong> &rarr; <em>Season 01</em> or <em>Season 12</em> &nbsp;|&nbsp;
						<strong>{EpisodeName}</strong> &rarr; <em>s01e05 - Title.mkv</em>; season/episode omitted when unknown; falls back to <em>Title 5 Chapters.mkv</em> when no TVDB title is set.
					</MudText>
				</MudAlert>
				<MudTextField @bind-Value="_trackDestinationTemplate"
					Label="Template"
					Variant="Variant.Outlined"
					FullWidth="true"
					Placeholder=@("{TVDBShow}\\Season {SeasonNumber}\\{EpisodeName}") />
			</MudCardContent>
		</MudCard>

		<MudCard>
			<MudCardContent>
				<MudText Typo="Typo.h6" Class="mb-2">Movie Track Destination</MudText>

				<MudText Typo="Typo.body2" Class="mb-3">
					Sub-path template for movie files. Supported variables:
				</MudText>
				<MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
					<MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
						OnClick="@(() => AppendToMovieTemplate("{SourceDisk}"))">{SourceDisk}</MudChip>
					<MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
						OnClick="@(() => AppendToMovieTemplate("{MovieName}"))">{MovieName}</MudChip>
					<MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
						OnClick="@(() => AppendToMovieTemplate("{MovieYear}"))">{MovieYear}</MudChip>
					<MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
						OnClick="@(() => AppendToMovieTemplate("{Resolution}"))">{Resolution}</MudChip>
				</MudStack>
				<MudAlert Severity="Severity.Info" Dense="true" Class="mb-3" NoIcon="false">
					<MudText Typo="Typo.caption">
						<strong>{MovieName}</strong> &rarr; <em>The Matrix</em> &nbsp;|&nbsp;
						<strong>{MovieYear}</strong> &rarr; <em>1999</em> &nbsp;|&nbsp;
						<strong>{Resolution}</strong> &rarr; <em>1080p</em> or <em>720p</em> (auto-detected or manually selected)
					</MudText>
				</MudAlert>
				<MudTextField @bind-Value="_movieTrackDestinationTemplate"
					Label="Template"
					Variant="Variant.Outlined"
					FullWidth="true"
					Placeholder=@("Movies\\{MovieName} ({MovieYear})\\{Resolution}") />
			</MudCardContent>
		</MudCard>

		<MudCard>
			<MudCardContent>
				<MudText Typo="Typo.h6" Class="mb-3">Audio</MudText>
				<MudSelect T="AudioDefault" @bind-Value="_audioDefault"
					Label="Default Audio Codec"
					Variant="Variant.Outlined"
					AnchorOrigin="Origin.BottomCenter"
					Style="max-width: 220px;">
					<MudSelectItem Value="AudioDefault.Opus">Opus</MudSelectItem>
					<MudSelectItem Value="AudioDefault.Aac">AAC</MudSelectItem>
				</MudSelect>
			</MudCardContent>
		</MudCard>

		<MudCard>
			<MudCardContent>
				<MudText Typo="Typo.h6" Class="mb-3">Languages</MudText>

				<MudSelect T="string" Label="Audio Languages" MultiSelection="true"
					@bind-SelectedValues="_selectedAudioLanguages"
					Variant="Variant.Outlined" Class="mb-4"
					HelperText="Languages for audio track selection by the runner">
					@foreach (var lang in _allLanguages)
					{
						<MudSelectItem T="string" Value="@lang.Code">@lang.Name (@lang.Code)</MudSelectItem>
					}
				</MudSelect>

				<MudSelect T="string" Label="Subtitle Languages" MultiSelection="true"
					@bind-SelectedValues="_selectedSubtitleLanguages"
					Variant="Variant.Outlined"
					HelperText="Languages for subtitle track selection by the runner">
					@foreach (var lang in _allLanguages)
					{
						<MudSelectItem T="string" Value="@lang.Code">@lang.Name (@lang.Code)</MudSelectItem>
					}
				</MudSelect>
			</MudCardContent>
		</MudCard>

		<MudCard>
			<MudCardContent>
				<MudText Typo="Typo.h6" Class="mb-3">TVDB Language</MudText>
				<MudSelect T="string" @bind-Value="_tvdbLanguage"
					Label="Preferred Metadata Language"
					Variant="Variant.Outlined"
					AnchorOrigin="Origin.BottomCenter"
					Style="max-width: 300px;"
					HelperText="When a series is not in this language, translated names will be fetched from TVDB">
					@foreach (var lang in _allLanguages)
					{
						<MudSelectItem T="string" Value="@lang.Code">@lang.Name (@lang.Code)</MudSelectItem>
					}
				</MudSelect>
			</MudCardContent>
		</MudCard>

		<MudCard>
			<MudCardContent>
				<MudText Typo="Typo.h6" Class="mb-3">HandBrake Presets</MudText>
				@if (_presets.Count == 0)
				{
					<MudText Typo="Typo.body2" Style="opacity:.7" Class="mb-2">No presets configured.</MudText>
				}
				else
				{
					<MudTable Items="_presets" Dense="true" Hover="true" Breakpoint="Breakpoint.Xs" Class="mb-3">
						<HeaderContent>
							<MudTh>Label</MudTh>
							<MudTh>Root</MudTh>
							<MudTh>Path</MudTh>
							<MudTh></MudTh>
						</HeaderContent>
						<RowTemplate>
							<MudTd DataLabel="Label">@context.Label</MudTd>
							<MudTd DataLabel="Root">@context.RootLabel</MudTd>
							<MudTd DataLabel="Path">
								<MudText Typo="Typo.caption">@context.RelativePath</MudText>
							</MudTd>
							<MudTd>
								<MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
									Size="Size.Small" Title="Delete preset"
									OnClick="@(() => DeletePresetAsync(context.Id))" />
							</MudTd>
						</RowTemplate>
					</MudTable>
				}
				<MudButton Variant="Variant.Outlined" Color="Color.Primary"
					StartIcon="@Icons.Material.Filled.Add"
					OnClick="AddPresetAsync">
					Add Preset
				</MudButton>
			</MudCardContent>
		</MudCard>

		<div>
			<MudButton Variant="Variant.Filled" Color="Color.Primary"
				OnClick="SaveAsync" Disabled="_isSaving"
				StartIcon="@Icons.Material.Filled.Save">
				@if (_isSaving)
				{
					<MudProgressCircular Indeterminate="true" Size="Size.Small" Class="mr-2" />
				}
				Save Settings
			</MudButton>
		</div>

	</MudStack>
}
