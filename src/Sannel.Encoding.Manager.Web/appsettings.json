{
	"Database": {
		"Provider": "sqlite",
		"ConnectionString": "Data Source=data/encoding.db"
	},
	"AzureAd": {
		"Instance": "https://login.microsoftonline.com/",
		"Domain": "yourdomain.onmicrosoft.com",
		"TenantId": "your-tenant-id-guid",
		"ClientId": "your-client-id-guid",
		"ClientSecret": "-- never store secrets here; use user-secrets or environment variables --",
