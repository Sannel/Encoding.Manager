{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_CLIENT_ID",
    "ClientSecret": "YOUR_CLIENT_SECRET"
  },
  "Runner": {
    "Name": "runner-01",
    "ServiceBaseUrl": "https://localhost:7001",
    "PollIntervalSeconds": 60
  },
  "HandBrake": {
    "ExecutablePath": "",
    "MinimumVersion": "10.1",
    "ScanOutputPath": "handbrake-scans"
  },
  "Filesystem": {
    "Roots": [
      {
        "Label": "media",
        "Path": "/mnt/media"
      }
    ]
  }
}
